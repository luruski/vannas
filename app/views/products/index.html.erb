<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Vanna's Bakery</h1>
    <p class="lead text-muted">Custom cakes and cupcakes baked fresh in Winnipeg, MB</p>
  </div>

  <%= render "category_nav" %>

  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @products.each do |product| %>
      <%= render "product_card", product: product %>
    <% end %>
  </div>
</div>