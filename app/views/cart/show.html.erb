<div class="container py-5">
  <h1 class="mb-4">Your Cart</h1>

  <% if @cart_products.empty? %>
    <div class="text-center py-5">
      <h4 class="text-muted">Your cart is empty.</h4>
      <%= link_to "Browse Products", root_path, class: "btn btn-primary mt-3" %>
    </div>
  <% else %>
    <div class="card shadow-sm mb-4">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Subtotal</th>
              <th>Remove</th>
            </tr>
          </thead>
          <tbody>
            <% @cart_products.each do |item| %>
              <tr>
                <td class="align-middle">
                  <%= link_to item[:product].name, product_path(item[:product]) %>
                </td>
                <td class="align-middle"><%= number_to_currency(item[:product].price) %></td>
                <td class="align-middle" style="width: 180px;">
                  <%= form_with url: update_cart_path(item[:product].id), method: :patch, local: true do |f| %>
                    <div class="input-group input-group-sm">
                      <%= f.number_field :quantity, value: item[:quantity], min: 1, class: "form-control" %>
                      <%= f.submit "Update", class: "btn btn-outline-secondary btn-sm" %>
                    </div>
                  <% end %>
                </td>
                <td class="align-middle"><%= number_to_currency(item[:subtotal]) %></td>
                <td class="align-middle">
                  <%= button_to "Remove", remove_from_cart_path(item[:product].id),
                      method: :delete,
                      class: "btn btn-danger btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="table-light">
              <td colspan="3" class="text-end fw-bold fs-5">Total:</td>
              <td colspan="2" class="fw-bold fs-5"><%= number_to_currency(@total) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="d-flex justify-content-between">
      <%= link_to "Continue Shopping", root_path, class: "btn btn-outline-secondary" %>
      <%= link_to "Proceed to Checkout", root_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>